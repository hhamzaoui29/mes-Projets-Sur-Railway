<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || "Mon Portfolio" %></title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- CSS du header (spécifique) -->
    <link rel="stylesheet" href="/portfolio/css/header.css">
    
    <!-- Ton CSS principal (avec main-container) -->
    <link rel="stylesheet" href="/portfolio/css/portfolio.css">
    
    <!-- CSS du footer (spécifique) -->
    <link rel="stylesheet" href="/portfolio/css/footer.css">
</head>
<body>
  
    <!-- Barre de navigation -->
    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container">
