<%- include('./partials/headerPortfolio') %>

<!-- CONTAINER PRINCIPAL UNIQUE -->
<div class="main-container">
    
    <!-- ===== EN-TÊTE ===== -->
    <div class="main-header">
        <div class="header-badge">✨ Développeur Full Stack</div>
        <h1>Bienvenue sur mon <span class="gradient-text">Portfolio</span></h1>
    </div>
    
    <!-- ===== SECTION HERO INTÉGRÉE ===== -->
    <div class="hero-section">
        <div class="text-center">
            <h2 class="hero-title">Applications Web Modernes</h2>
            <p class="hero-description">
                Je conçois et déploie des applications web qui allient
                <span class="highlight">simplicité</span>, 
                <span class="highlight">efficacité</span> et 
                <span class="highlight">organisation</span>.
            </p>
            <p class="text-secondary mb-4">
                <i class="fas fa-rocket me-2"></i>
                Site vitrine • Questionnaires • Factures • Lettres
            </p>
            
            <div class="hero-stats">
                <div class="stat-card">
                    <div class="stat-number">4+</div>
                    <div class="stat-label">Applications</div>
                </div>
                <div class="stat-card">
                    <div class="stat-number">100%</div>
                    <div class="stat-label">Responsive</div>
                </div>
                <div class="stat-card">
                    <div class="stat-number">PDF</div>
                    <div class="stat-label">Dynamique</div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- ===== SÉPARATEUR ===== -->
    <div class="section-divider">
        <div class="divider-line"></div>
        <div class="divider-icon">📂</div>
    </div>
    
    <!-- ===== SECTION PROJETS ===== -->
    <div class="section-title">
        <div class="section-icon">🚀</div>
        <div class="section-text">
            <h2>Mes Réalisations</h2>
            <p>Découvrez mes projets récents</p>
        </div>
    </div>
    
    <!-- Filtres -->
    <div class="filters-wrapper">
        <button class="filter-btn active" data-filter="all">Tous</button>
        <button class="filter-btn" data-filter="web">Web</button>
        <button class="filter-btn" data-filter="pdf">PDF</button>
        <button class="filter-btn" data-filter="admin">Admin</button>
    </div>
    
    <!-- Grille des projets -->
    <div class="projects-grid">
        <% let sections = [
            { 
                icon: "🌐", 
                title: "Site Vitrine", 
                category: "web",
                badge: "CRUD",
                description: [
                    "Site vitrine avec partie publique et admin",
                    "Gestion CRUD complète",
                    "Formulaire de contact avec SQLite",
                    "Interface responsive"
                ], 
                tags: ["Node.js", "Express", "SQLite"],
                link: "/site/vitrine",
                target: "_blank",
                btn: "Voir le projet",
                color: "primary"
            },
            { 
                icon: "📝", 
                title: "Questionnaire PDF", 
                category: "pdf",
                badge: "JSON",
                description: [
                    "Création de questionnaires",
                    "Enregistrement en JSON",
                    "Génération PDF structuré",
                    "Architecture MVC"
                ],
                tags: ["Node.js", "pdf-lib", "JSON"],
                link: "/q",
                target: "_blank",
                btn: "Voir le projet",
                color: "success"
            },
            { 
                icon: "🧾", 
                title: "Factures PDF", 
                category: "pdf",
                badge: "PDF",
                description: [
                    "Gestion de factures",
                    "Calcul HT/TVA/TTC",
                    "PDF avec tableau",
                    "Stockage JSON"
                ],
                tags: ["Node.js", "PDF-lib", "Bootstrap"],
                link: "/f",
                target: "_blank",
                btn: "Voir le projet",
                color: "warning"
            },
            { 
                icon: "✉️", 
                title: "Lettres PDF", 
                category: "pdf",
                badge: "Nouveau",
                description: [
                    "Création de lettres",
                    "Génération PDF",
                    "Gestion JSON",
                    "Identifiants uniques"
                ],
                tags: ["Node.js", "PDF-lib", "EJS"],
                link: "/l",
                target: "_blank",
                btn: "Voir le projet",
                color: "info"
            }
        ]; %>
    
        <% sections.forEach((section, index) => { %>
            <!-- Carte de projet -->
            <div class="project-card" data-category="<%= section.category %>">
                
                <% if (section.badge) { %>
                                        <div class="project-badge"><%= section.badge %></div>
                                    <% } %>
                
                <div class="project-header">
                    <div class="project-icon"><%= section.icon %></div>
                        <div>
                            <h3 class="project-title"><%= section.title %></h3>
                            <div class="project-category">
                                <i class="fas fa-tag"></i> <%= section.category %>
                            </div>
                        </div>
                </div>
                
                <div class="project-tags">
                    <% section.tags.forEach(tag => { %>
                        <span class="project-tag"><%= tag %></span>
                    <% }); %>
                </div>
                
                <div class="project-description">
                    <ul class="feature-list">
                        <% section.description.forEach(line => { %>
                                                                    <li>
                                                                        <i class="fas fa-check-circle"></i>
                                                                        <%= line %>
                                                                    </li>
                                                                <% }); %>
                    </ul>
                </div>
                
                <div class="project-footer">
                        <a href="<%= section.link %>" class="btn btn-<%= section.color %>" target="<%= section.target || '_self' %>"  rel="<%= section.target === '_blank' ? 'noopener noreferrer' : '' %>">
                        <span><%= section.btn %></span>
                        <i class="fas fa-arrow-right"></i>
                    </a>
                </div>
            </div>
        <% }); %>
    </div>
    
</div>
<!-- FIN DU CONTAINER PRINCIPAL -->

<!-- Script pour les filtres -->
<script>
    document.addEventListener('DOMContentLoaded', function() {
        const filterButtons = document.querySelectorAll('.filter-btn');
        const projectCards = document.querySelectorAll('.project-card');

        filterButtons.forEach(button => {
            button.addEventListener('click', function() {
                filterButtons.forEach(btn => btn.classList.remove('active'));
                this.classList.add('active');

                const filterValue = this.getAttribute('data-filter');

                projectCards.forEach(card => {
                    if (filterValue === 'all' || card.getAttribute('data-category') === filterValue) {
                        card.style.display = 'flex';
                        setTimeout(() => {
                            card.style.opacity = '1';
                            card.style.transform = 'translateY(0)';
                        }, 50);
                    } else {
                        card.style.opacity = '0';
                        card.style.transform = 'translateY(30px)';
                        setTimeout(() => {
                            card.style.display = 'none';
                        }, 300);
                    }
                });
            });
        });
    });
</script>

<%- include('./partials/footerPortfolio') %>

