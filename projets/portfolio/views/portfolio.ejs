<%- include('./partials/headerPortfolio') %>

    <!-- Bandeau d’accueil (Hero) -->
    <section class="bg-light text-dark py-5 text-center shadow-sm">
      <div class="container">
        <h1 class="display-5 fw-bold">🚀 Bienvenue sur mon Portfolio</h1>
        <p class="lead mt-3">
          Ici, je conçois et déploie des applications web modernes qui allient
          <strong>simplicité</strong>, <strong>efficacité</strong> et <strong>organisation</strong>.
        </p>
        <p class="mt-2">
               Découvrez mes projets : site vitrine, application de questionnaires et génération dynamique de factures en PDF à partir des données saisies via formulaire ou via fichier JSON
        </p>
        
      </div>
    </section>

    <!-- Section Applications -->
    <div class="container py-5" id="applications">
        <h2 class="text-center mb-4">📂 Mes Applications</h2>
        <div class="features-section">
            <% let sections = [
                { 
                    icon: "🌐", 
                    title: "Site Vitrine", 
                    description: [
                                      "Partie publique : affichage du dashboard, services, galeries et formulaire de contact",
                                      "Partie admin : gestion complète CRUD pour utilisateurs, services, galeries et messages de contact",
                                      "Formulaire de contact avec sauvegarde en base SQLite",
                                      "Interface responsive (mobile / desktop) ",
                                      "Système de notifications pour les messages non lus dans l’admin",
                                      "Pagination et statut Lu/Non lu pour les messages de contact",
                                      "Stockage des données dans SQLite via Sequelize",
                                      "Architecture MVC avec routes, controllers, models et views"
                                ], 
                    link: "/site/vitrine",
                    btn: "👁️ Voir"
                },
                { 
                    icon: "📝", 
                    title: "Générateur de Questionnaire PDF", 
                    description: [
                        "Création dynamique de questionnaires personnalisés",
                        "Saisie et enregistrement des réponses dans un fichier JSON",
                        "Architecture MVC modulaire (feature-based structure)",
                        "Génération automatique d’un document PDF structuré en tableau",
                        "Gestion des routes, controllers et services séparés",
                        "Stockage local des données (JSON) et génération serveur-side avec pdf-lib",
                        "Interface responsive avec EJS + Bootstrap"
                    ],
                    link: "/q",
                    btn: "👁️ Voir"
                   },
                   { 
                        icon: "🧾", 
                        title: "Générateur de Factures PDF", 
                        description: [
                            "Création et gestion de factures dynamiques",
                            "Stockage des données dans un fichier JSON",
                            "Calcul automatique HT, TVA et Total TTC",
                            "Génération de facture PDF avec tableau structuré",
                            "Architecture MVC modulaire par feature",
                            "Séparation des controllers, services et data",
                            "Interface responsive avec EJS + Bootstrap",
                        ],
                        link: "/f",
                        btn: "👁️ Voir"
                    },
                    { 
                        icon: "✉️", 
                        title: "Application de génération de lettres PDF", 
                        description: [
                            "Application web permettant la création et la gestion de lettres dynamiques",
                            "Persistance des données via stockage JSON structuré",
                            "Génération de documents PDF à partir des données sauvegardées",
                            "Architecture MVC modulaire organisée par feature",
                            "Séparation claire des Controllers, Services et couche Data",
                            "Interface responsive développée avec EJS et Bootstrap",
                            "Gestion des identifiants uniques et routage dynamique",
                            "Manipulation avancée du PDF (polices personnalisées, mise en page structurée)"
                        ],
                        link: "/l",
                        btn: "🔎 Voir le projet"
                    }

               
            ]; %>
    
            <% sections.forEach(section => { %>
                <div class="feature-row d-flex align-items-center justify-content-between mb-3 p-3 border rounded shadow-sm">
                    <div class="feature-text">
                        <h4><%= section.icon %> <%= section.title %></h4>
                        <ul class="mb-0">
                            <% section.description.forEach(line => { %>
                                <li><%= line %></li>
                            <% }); %>
                        </ul>
                    </div>
                    <div class="feature-action ms-3">
                        <a href="<%= section.link %>" class="btn btn-sm btn-info"><%= section.btn %></a>
                    </div>
                </div>
            <% }); %>
        </div>
    </div>

<%- include('./partials/footerPortfolio') %>
