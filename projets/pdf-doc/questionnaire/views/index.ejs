<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gestionnaire de Questionnaires</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 20px;
        }
        
        .container {
            max-width: 1200px;
            margin: 0 auto;
        }
        
        .header {
            background: white;
            padding: 30px;
            border-radius: 15px;
            margin-bottom: 30px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        
        .header h1 {
            color: #333;
            font-size: 2em;
        }
        
        .btn {
            padding: 12px 24px;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-size: 16px;
            font-weight: 600;
            text-decoration: none;
            display: inline-block;
            transition: transform 0.3s, box-shadow 0.3s;
            margin-left: 10px;
        }
        
        .btn-primary {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
        }
        
        .btn-success {
            background: linear-gradient(135deg, #84fab0 0%, #8fd3f4 100%);
            color: #333;
        }
        
        .btn-info {
            background: linear-gradient(135deg, #f6d365 0%, #fda085 100%);
            color: white;
        }
        
        .btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(0,0,0,0.3);
        }
        
        .alert {
            padding: 15px;
            border-radius: 10px;
            margin-bottom: 20px;
        }
        
        .alert-success {
            background: #d4edda;
            color: #155724;
        }
        
        .alert-error {
            background: #f8d7da;
            color: #721c24;
        }
        
        .questionnaires-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 20px;
        }
        
        .questionnaire-card {
            background: white;
            border-radius: 15px;
            padding: 25px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.1);
            transition: transform 0.3s;
        }
        
        .questionnaire-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 25px rgba(0,0,0,0.15);
        }
        
        .questionnaire-card h3 {
            color: #333;
            margin-bottom: 10px;
        }
        
        .questionnaire-card p {
            color: #666;
            margin-bottom: 20px;
        }
        
        .actions {
            display: flex;
            gap: 10px;
        }
        
        .btn-small {
            padding: 8px 16px;
            font-size: 14px;
        }
        
        .empty-state {
            background: white;
            border-radius: 15px;
            padding: 50px;
            text-align: center;
            color: #666;
        }
        
        .empty-state p {
            margin: 20px 0;
            font-size: 1.2em;
        }
    </style>
</head>
<body>
    <div class="container">
        <% if (locals.message) { %>
            <div class="alert alert-success">
                <%= message %>
            </div>
        <% } %>
        
        <% if (locals.erreur) { %>
            <div class="alert alert-error">
                <%= erreur %>
            </div>
        <% } %>

        
        <div class="header">
            <h1>📋 Gestionnaire de Questionnaires</h1>
            <div>
                <a href="/q/formCreate" class="btn btn-primary">➕ Nouveau questionnaire</a>
            </div>
        </div>

         <div class="header">
            <h1>📋 Questionnaire / Reponses </h1>
            <div>
                <a href="/q/formSelect" class="btn btn-primary">➕ Commencer</a>
            </div>
        </div>

         <div class="header">
            <h1>📋 Affichage & Téléchargements</h1>
            <div>
                <a href="/q/views" class="btn btn-primary">📋 Affichage </a>
            </div>
        </div>
        
        <% if (questionnaires.length === 0) { %>
            <div class="empty-state">
                <h2>Aucun questionnaire pour le moment</h2>
                <p>Commencez par créer votre premier questionnaire</p>
                <a href="/q/formCreate" class="btn btn-primary">Créer à partir de zéro</a>
            </div>
        <% } else { %>
            <div class="questionnaires-grid">
                <% questionnaires.forEach(q => { %>
                    <div class="questionnaire-card">
                        <h3><%= q.nom %></h3>
                        <!--<p>📁 <%= q.chemin %></p>-->
                        <div class="actions">
                            <a href="# " class="btn btn-primary btn-small">👁️ Voir</a>
                            <a href="#" class="btn btn-primary btn-small"> 🗑️ Supprimer</a>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } %>
    </div>
    
    <script>
        // Faire disparaître les alertes après 3 secondes
        setTimeout(() => {
            document.querySelectorAll('.alert').forEach(alert => {
                alert.style.opacity = '0';
                setTimeout(() => alert.remove(), 500);
            });
        }, 3000);
    </script>
</body>
</html>