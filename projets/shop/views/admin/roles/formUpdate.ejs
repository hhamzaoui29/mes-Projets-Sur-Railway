<%
title = 'Modifier Rôle';
%>

<div class="container">
    <div class="page-header">
        <h1>Modifier le Rôle</h1>
        <a href="/shop/roles" class="btn btn-secondary">
            <i class="fas fa-arrow-left"></i> Retour à la liste
        </a>
    </div>

    <% if (flash && flash.message) { %>
        <div class="flash-message <%= flash.type %>">
            <%= flash.message %>
        </div>
    <% } %>

    <div class="form-container">
        <form action="/shop/roles/update/<%= role.id %>" method="POST">
            
            <!-- code rôle -->
            <div class="form-group">
                <label for="name"> Code rôle <span class="required">*</span></label>
                <input type="text" 
                       id="name" 
                       name="name" 
                       value="<%= role.name %>"
                       required 
                       class="form-control">
            </div>

            <!-- Nom de la rôle -->
            <div class="form-group">
                <label for="name">Nom du rôle <span class="required">*</span></label>
                <input type="text" 
                       id="displayName" 
                       name="displayName" 
                       value="<%= role.displayName %>"
                       required 
                       class="form-control">
            </div>

                     <!-- Permission du Rôle -->
            <div class="form-group">
                <label for="permission">Permission <span class="required">*</span></label>
                <input type="text" 
                       id="permission" 
                       name="permission" 
                       value="<%= role.permission %>"
                       required 
                       class="form-control">
                <small class="form-text">Séparez plusieurs permissions par des virgules</small>
            </div>


            <!-- Description -->
            <div class="form-group">
                <label for="description">Description</label>
                <textarea id="description" 
                          name="description" 
                          rows="3" 
                          class="form-control"><%= role.description || '' %></textarea>
            </div>

            <!-- Rôle parente -->
            <div class="form-group">
                <label for="parentId">Rôle parente</label>
                <select id="parentId" name="parentId" class="form-control">
                    <option value="">-- Aucune (rôle racine) --</option>
                    <% roles.forEach(role => { %>
                        <% if (role.id !== role.id) { // Empêcher de se prendre soi-même comme parent %>
                            <option value="<%= role.id %>" 
                                <%= role.parentId === role.id ? 'selected' : '' %>>
                                <%= role.name %>
                            </option>
                        <% } %>
                    <% }) %>
                </select>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save"></i> Mettre à jour
                </button>
                <a href="/shop/roles" class="btn btn-secondary">
                    Annuler
                </a>
            </div>
        </form>
    </div>
</div>

<!-- Réutiliser les mêmes styles que formCreate -->
<style>
.page-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 30px;
}

.form-container {
    background: white;
    padding: 30px;
    border-radius: 10px;
    box-shadow: var(--shadow);
    max-width: 600px;
    margin: 0 auto;
}

.form-group {
    margin-bottom: 20px;
}

.form-group label {
    display: block;
    margin-bottom: 5px;
    font-weight: 600;
}

.form-group .required {
    color: #e74c3c;
}

.form-control {
    width: 100%;
    padding: 10px;
    border: 1px solid #ddd;
    border-radius: 5px;
    font-family: inherit;
}

.form-control:focus {
    outline: none;
    border-color: #4f46e5;
    box-shadow: 0 0 0 3px rgba(79, 70, 229, 0.1);
}

.form-actions {
    display: flex;
    gap: 10px;
    margin-top: 30px;
}

.flash-message {
    padding: 15px;
    margin-bottom: 20px;
    border-radius: 5px;
}

.flash-message.success {
    background: #d4edda;
    color: #155724;
    border: 1px solid #c3e6cb;
}

.flash-message.error {
    background: #f8d7da;
    color: #721c24;
    border: 1px solid #f5c6cb;
}
</style>