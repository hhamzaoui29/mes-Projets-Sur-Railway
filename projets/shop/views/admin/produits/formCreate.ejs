<%
title = 'Nouveau produit';
%>

<div class="container">
    <div class="page-header">
        <h1>Ajouter un nouveau produit</h1>
        <a href="/shop/produits" class="btn btn-secondary">
            <i class="fas fa-arrow-left"></i> Retour
        </a>
    </div>

    <!-- Messages flash -->
    <% if (flash && flash.message) { %>
        <div class="flash-message <%= flash.type %>">
            <%= flash.message %>
        </div>
    <% } %>

    <!-- Formulaire avec enctype pour l'upload d'image -->
    <div class="form-container">
        <form action="/shop/produits/create" method="POST"  enctype="multipart/form-data">
            
            <!-- Nom du produit -->
            <div class="form-group">
                <label for="name">Nom du produit <span class="required">*</span></label>
                <input type="text" id="name"  name="name"  required class="form-control"   placeholder="Ex: T-shirt en coton bio">
            </div>

            <!-- Description -->
            <div class="form-group">
                <label for="description">Description</label>
                <textarea id="description"  name="description"  rows="4"  class="form-control" placeholder="Description détaillée du produit..."></textarea>
            </div>

            <!-- Prix et Stock sur 2 colonnes -->
            <div class="form-row">
                <div class="form-group half">
                    <label for="price">Prix (€) <span class="required">*</span></label>
                    <input type="number"  id="price"  name="price"  step="0.01"  min="0"  required  class="form-control" placeholder="29.99">
                </div>
                
                <div class="form-group half">
                    <label for="stock">Stock</label>
                    <input type="number"  id="stock"  name="stock"  min="0"  value="0"  class="form-control" placeholder="100">
                </div>
            </div>

            <!-- Catégorie -->
            <div class="form-group">
                <label for="categoryId">Catégorie</label>
                <select id="categoryId" name="categoryId" class="form-control">
                    <option value="">-- Choisir une catégorie --</option>
                    <% categories.forEach(cat => { %>
                        <option value="<%= cat.id %>">
                            <%= cat.name %>
                        </option>
                    <% }) %>
                </select>
            </div>

            <!-- Upload d'image -->
            <div class="form-group">
                <label for="image">Image du produit</label>
                <div class="file-input-wrapper">
                    <input type="file"  id="image"  name="image"  accept="image/jpeg,image/png,image/gif,image/webp" class="file-input">
                    <div class="file-input-preview" id="imagePreview">
                        <i class="fas fa-cloud-upload-alt"></i>
                        <p>Cliquez ou glissez une image</p>
                        <small>JPG, PNG, GIF, WebP (max 5Mo)</small>
                    </div>
                </div>
                <div id="previewContainer" style="display: none; margin-top: 10px;">
                    <img id="preview" src="#" alt="Aperçu" style="max-width: 200px; max-height: 200px;">
                </div>
            </div>

            <!-- Boutons -->
            <div class="form-actions">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save"></i> Créer le produit
                </button>
                <a href="/shop/produits" class="btn btn-secondary">
                    Annuler
                </a>
            </div>
        </form>
    </div>
</div>

<!-- Script pour l'aperçu de l'image -->
<script>
document.getElementById('image').addEventListener('change', function(e) {
    const file = e.target.files[0];
    if (file) {
        const reader = new FileReader();
        reader.onload = function(e) {
            document.getElementById('preview').src = e.target.result;
            document.getElementById('previewContainer').style.display = 'block';
            document.querySelector('.file-input-preview').style.display = 'none';
        };
        reader.readAsDataURL(file);
    } else {
        document.getElementById('previewContainer').style.display = 'none';
        document.querySelector('.file-input-preview').style.display = 'block';
    }
});
</script>

<!-- Styles -->
<style>
.page-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 30px;
}

.form-container {
    background: white;
    padding: 30px;
    border-radius: 10px;
    box-shadow: var(--shadow);
    max-width: 600px;
    margin: 0 auto;
}

.form-row {
    display: flex;
    gap: 20px;
    margin-bottom: 20px;
}

.form-group {
    margin-bottom: 20px;
    flex: 1;
}

.form-group.half {
    margin-bottom: 0;
}

.form-group label {
    display: block;
    margin-bottom: 5px;
    font-weight: 600;
}

.form-group .required {
    color: #e74c3c;
}

.form-control {
    width: 100%;
    padding: 10px;
    border: 1px solid #ddd;
    border-radius: 5px;
    font-family: inherit;
}

.form-control:focus {
    outline: none;
    border-color: #4f46e5;
    box-shadow: 0 0 0 3px rgba(79, 70, 229, 0.1);
}

/* Style pour l'upload d'image */
.file-input-wrapper {
    position: relative;
    margin-top: 5px;
}

.file-input {
    position: absolute;
    width: 100%;
    height: 100%;
    opacity: 0;
    cursor: pointer;
    z-index: 2;
}

.file-input-preview {
    border: 2px dashed #ddd;
    border-radius: 10px;
    padding: 30px;
    text-align: center;
    background: #f9fafb;
    transition: all 0.3s;
}

.file-input-preview:hover {
    border-color: #4f46e5;
    background: #eef2ff;
}

.file-input-preview i {
    font-size: 3rem;
    color: #9ca3af;
    margin-bottom: 10px;
}

.file-input-preview p {
    margin: 0;
    color: #374151;
}

.file-input-preview small {
    color: #6b7280;
    font-size: 0.85rem;
}

#previewContainer {
    text-align: center;
}

#preview {
    border-radius: 10px;
    box-shadow: var(--shadow);
}

.form-actions {
    display: flex;
    gap: 10px;
    margin-top: 30px;
}

.flash-message {
    padding: 15px;
    margin-bottom: 20px;
    border-radius: 5px;
}

.flash-message.success {
    background: #d4edda;
    color: #155724;
    border: 1px solid #c3e6cb;
}

.flash-message.error {
    background: #f8d7da;
    color: #721c24;
    border: 1px solid #f5c6cb;
}
</style>