<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || "Mon Portfolio" %></title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- CSS du header (spécifique) -->
    <link rel="stylesheet" href="/portfolio/css/header.css">
    
    <!-- Ton CSS principal (avec main-container) -->
    <link rel="stylesheet" href="/portfolio/css/portfolio.css">
    
    <!-- CSS du footer (spécifique) -->
    <link rel="stylesheet" href="/portfolio/css/footer.css">
</head>
<body>
  
    <!-- Barre de navigation -->
    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container">
            <!-- Logo gauche (visible seulement sur mobile) -->
            <a class="navbar-brand d-lg-none" href="/">
                <i class="fas fa-code me-2"></i>Hamzaoui H.
            </a>
            
            <!-- Bouton hamburger -->
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            
            <!-- Menu de navigation -->
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav mx-auto align-items-center">
                    <li class="nav-item">
                        <a class="nav-link" href="/">
                            <i class="fas fa-home"></i> Accueil
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#applications">
                            <i class="fas fa-project-diagram"></i> Projets
                        </a>
                    </li>
                    <li class="nav-item mx-lg-3">
                        <a class="navbar-brand" href="/composants" target="_blank">
                            <i class="fas fa-id-card"></i> Mon CV En Ligne
                            <i class="fas fa-external-link-alt"></i>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/competences">
                            <i class="fas fa-cog"></i> Compétences
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/contact">
                            <i class="fas fa-envelope"></i> Contact
                        </a>
                    </li>
                </ul>
            </div>
            
            <!-- Icônes sociales (desktop) -->
            <div class="social-icons d-none d-lg-flex">
                <a href="#"><i class="fab fa-github"></i></a>
                <a href="#"><i class="fab fa-linkedin-in"></i></a>
                <a href="#"><i class="fab fa-twitter"></i></a>
            </div>
        </div>
    </nav>

    <!-- Contenu principal de la page -->
    <main class="main"> 
        <%- body %> 
    </main>
    <footer class="footer">
    <div class="container">
        <!-- Section principale (celle que vous aviez) -->
        <div class="footer-main">
           
            
            <!-- Badges de confiance -->
            <div class="trust-badges">
                <span class="trust-badge">
                    <i class="fas fa-check-circle"></i> Satisfaction client
                </span>
                <span class="trust-badge">
                    <i class="fas fa-shield-alt"></i> Garantie qualité
                </span>
                <span class="trust-badge">
                    <i class="fas fa-clock"></i> Support réactif
                </span>
            </div>
        </div>
        
        <!-- Icônes sociales -->
        <div class="social-links">
            <a href="#" class="social-link" target="_blank" rel="noopener noreferrer">
                <i class="fab fa-facebook-f"></i>
            </a>
            <a href="#" class="social-link" target="_blank" rel="noopener noreferrer">
                <i class="fab fa-instagram"></i>
            </a>
            <a href="#" class="social-link" target="_blank" rel="noopener noreferrer">
                <i class="fab fa-pinterest-p"></i>
            </a>
            <a href="#" class="social-link" target="_blank" rel="noopener noreferrer">
                <i class="fab fa-github"></i>
            </a>
            <a href="#" class="social-link" target="_blank" rel="noopener noreferrer">
                <i class="fab fa-linkedin-in"></i>
            </a>
        </div>
        
        <!-- Copyright -->
        <div class="footer-bottom">
            <p class="copyright">
                <i class="far fa-copyright"></i> 
                <%= new Date().getFullYear() %> Hamzaoui Hamid. 
            </p>
            <p>
                <i class="fas fa-code-branch me-2"></i>
                Version 2.0 - Tous droits réservés
            </p>
        </div>
    </div>
</footer>

<!-- Bootstrap JS -->
<script src="/portfolio/js/bootstrap.bundle.min.js"></script>

<!-- Script optionnel pour animations supplémentaires -->
<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Animation des icônes sociales au survol
        const socialLinks = document.querySelectorAll('.social-link');
        socialLinks.forEach(link => {
            link.addEventListener('mouseenter', function() {
                this.style.transform = 'translateY(-5px)';
            });
            link.addEventListener('mouseleave', function() {
                this.style.transform = 'translateY(0)';
            });
        });
    });
</script>

</body>
</html>