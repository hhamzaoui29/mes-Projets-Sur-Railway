<%
title = 'Gestion des catégories';
%>

<div class="container">
    <div class="page-header">
        <h1>Catégories</h1>
        <a href="/shop/categories/formCreate" class="btn btn-primary">
            <i class="fas fa-plus"></i> Nouvelle catégorie
        </a>
    </div>

    <% if (flash && flash.message) { %>
        <div class="flash-message <%= flash.type %>">
            <%= flash.message %>
        </div>
    <% } %>

    <% if (categories && categories.length > 0) { %>
        <div class="categories-grid">
            <% categories.forEach(cat => { %>
                <div class="category-card">
                    <h3><%= cat.name %></h3>
                    <% if (cat.description) { %>
                        <p><%= cat.description %></p>
                    <% } %>
                    <div class="category-actions">
                        <a href="/shop/categories/formUpdate/<%= cat.id %>/" class="btn btn-small">
                            <i class="fas fa-edit"></i>
                        </a>
                        <form action="/shop/categories/delete/<%= cat.id %>" 
                              method="POST" 
                              style="display: inline;">
                            <button type="submit" class="btn btn-small btn-danger" 
                                    onclick="return confirm('Supprimer cette catégorie ?')">
                                <i class="fas fa-trash"></i>
                            </button>
                        </form>
                    </div>
                </div>
            <% }) %>
        </div>
    <% } else { %>
        <p class="no-data">Aucune catégorie pour le moment.</p>
    <% } %>
</div>

<style>
.page-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 30px;
}

.categories-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 20px;
}

.category-card {
    background: white;
    padding: 20px;
    border-radius: 10px;
    box-shadow: var(--shadow);
}

.category-card h3 {
    margin-bottom: 10px;
    color: var(--primary-color);
}

.category-card p {
    color: #666;
    margin-bottom: 15px;
    font-size: 0.9rem;
}

.category-actions {
    display: flex;
    gap: 10px;
    justify-content: flex-end;
}

.btn-small {
    padding: 5px 10px;
    font-size: 0.9rem;
}

.btn-danger {
    background: #dc3545;
    color: white;
}

.btn-danger:hover {
    background: #c82333;
}

.no-data {
    text-align: center;
    padding: 40px;
    color: #666;
    background: white;
    border-radius: 10px;
    box-shadow: var(--shadow);
}
</style>