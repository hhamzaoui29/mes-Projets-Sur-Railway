<%
title = 'Tableau de bord';
%>

<div class="dashboard">
    <h1 class="dashboard-title">Tableau de bord</h1>

    <!-- Statistiques principales -->
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-icon users">
                <i class="fas fa-users"></i>
            </div>
            <div class="stat-content">
                <h3><%= stats.totalUsers %></h3>
                <p>Utilisateurs</p>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon products">
                <i class="fas fa-box"></i>
            </div>
            <div class="stat-content">
                <h3><%= stats.totalProducts %></h3>
                <p>Produits</p>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon categories">
                <i class="fas fa-tags"></i>
            </div>
            <div class="stat-content">
                <h3><%= stats.totalCategories %></h3>
                <p>Catégories</p>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon stock">
                <i class="fas fa-warehouse"></i>
            </div>
            <div class="stat-content">
                <h3><%= stats.totalStock %></h3>
                <p>Articles en stock</p>
            </div>
        </div>
    </div>

    <!-- Deuxième ligne de stats -->
    <div class="stats-grid secondary">
        <div class="stat-card small">
            <div class="stat-icon warning">
                <i class="fas fa-exclamation-triangle"></i>
            </div>
            <div class="stat-content">
                <h3><%= stats.outOfStock %></h3>
                <p>Rupture de stock</p>
            </div>
        </div>

        <div class="stat-card small">
            <div class="stat-icon value">
                <i class="fas fa-euro-sign"></i>
            </div>
            <div class="stat-content">
                <h3><%= stats.totalValue %> €</h3>
                <p>Valeur du stock</p>
            </div>
        </div>

        <div class="stat-card small">
            <div class="stat-icon roles">
                <i class="fas fa-user-tag"></i>
            </div>
            <div class="stat-content">
                <h3><%= stats.totalRoles %></h3>
                <p>Rôles</p>
            </div>
        </div>
    </div>

    <!-- Deux colonnes -->
    <div class="dashboard-row">
        <!-- Colonne gauche : Utilisateurs récents -->
        <div class="dashboard-col">
            <div class="dashboard-card">
                <div class="card-header">
                    <h2>Derniers utilisateurs</h2>
                    <a href="/shop/users" class="btn-small">Voir tout</a>
                </div>
                <div class="card-body">
                    <% if (recentUsers && recentUsers.length > 0) { %>
                        <table class="mini-table">
                            <thead>
                                <tr>
                                    <th>Nom</th>
                                    <th>Email</th>
                                    <th>Date</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% recentUsers.forEach(user => { %>
                                    <tr>
                                        <td><%= user.nom %> <%= user.prenom %></td>
                                        <td><%= user.email %></td>
                                        <td><%= new Date(user.createdAt).toLocaleDateString('fr-FR') %></td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    <% } else { %>
                        <p class="no-data">Aucun utilisateur récent</p>
                    <% } %>
                </div>
            </div>

            <!-- Répartition par rôle -->
            <div class="dashboard-card">
                <div class="card-header">
                    <h2>Utilisateurs par rôle</h2>
                     <a href="/shop/roles" class="btn-small">Gerer les roles</a>
                </div>
                <div class="card-body">
                    <div class="role-stats">
                        <% for (const [role, count] of Object.entries(usersByRole)) { %>
                            <div class="role-item">
                                <span class="role-name"><%= role %></span>
                                <span class="role-count"><%= count %></span>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>

        <!-- Colonne droite : Produits récents -->
        <div class="dashboard-col">
            <div class="dashboard-card">
                <div class="card-header">
                    <h2>Derniers produits</h2>
                    <a href="/shop/products" class="btn-small">Voir tout</a>
                </div>
                <div class="card-body">
                    <% if (recentProducts && recentProducts.length > 0) { %>
                        <table class="mini-table">
                            <thead>
                                <tr>
                                    <th>Produit</th>
                                    <th>Prix</th>
                                    <th>Stock</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% recentProducts.forEach(product => { %>
                                    <tr>
                                        <td><%= product.name %></td>
                                        <td><%= product.price %> €</td>
                                        <td><%= product.stock || 0 %></td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    <% } else { %>
                        <p class="no-data">Aucun produit récent</p>
                    <% } %>
                </div>
            </div>

            <!-- Catégories avec compteurs -->
            <div class="dashboard-card">
                <div class="card-header">
                    <h2>Catégories</h2>
                    <a href="/shop/categories" class="btn-small">Gérer</a>
                </div>
                <div class="card-body">
                    <div class="category-stats">
                        <% categoriesWithCount.forEach(cat => { %>
                            <div class="category-item">
                                <span class="category-name"><%= cat.name %></span>
                                <span class="category-count"><%= cat.productCount %> produits</span>
                            </div>
                        <% }) %>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Styles -->
<style>
.dashboard {
    padding: 20px;
}

.dashboard-title {
    margin-bottom: 30px;
    color: var(--text-color);
}

.stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 20px;
    margin-bottom: 20px;
}

.stats-grid.secondary {
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    margin-bottom: 30px;
}

.stat-card {
    background: white;
    border-radius: 10px;
    padding: 20px;
    box-shadow: var(--shadow);
    display: flex;
    align-items: center;
    gap: 15px;
    transition: transform 0.3s;
}

.stat-card:hover {
    transform: translateY(-2px);
}

.stat-card.small {
    padding: 15px;
}

.stat-icon {
    width: 50px;
    height: 50px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    color: white;
}

.stat-icon.users { background: #4f46e5; }
.stat-icon.products { background: #10b981; }
.stat-icon.categories { background: #f59e0b; }
.stat-icon.stock { background: #6366f1; }
.stat-icon.warning { background: #ef4444; }
.stat-icon.value { background: #8b5cf6; }
.stat-icon.roles { background: #ec4899; }

.stat-content h3 {
    font-size: 1.8rem;
    margin: 0;
    color: var(--text-color);
}

.stat-content p {
    margin: 0;
    color: #666;
    font-size: 0.9rem;
}

.dashboard-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
}

.dashboard-card {
    background: white;
    border-radius: 10px;
    box-shadow: var(--shadow);
    margin-bottom: 20px;
    overflow: hidden;
}

.card-header {
    background: #f9fafb;
    padding: 15px 20px;
    border-bottom: 1px solid #eee;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.card-header h2 {
    margin: 0;
    font-size: 1.2rem;
    color: var(--text-color);
}

.btn-small {
    padding: 5px 10px;
    background: var(--primary-color);
    color: white;
    text-decoration: none;
    border-radius: 5px;
    font-size: 0.9rem;
}

.btn-small:hover {
    background: var(--primary-dark);
}

.card-body {
    padding: 20px;
}

.mini-table {
    width: 100%;
    border-collapse: collapse;
}

.mini-table th {
    text-align: left;
    padding: 8px;
    border-bottom: 2px solid #eee;
    color: #666;
    font-weight: 600;
    font-size: 0.9rem;
}

.mini-table td {
    padding: 8px;
    border-bottom: 1px solid #eee;
}

.mini-table tr:hover {
    background: #f9fafb;
}

.role-stats, .category-stats {
    display: flex;
    flex-direction: column;
    gap: 10px;
}

.role-item, .category-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 8px;
    background: #f9fafb;
    border-radius: 5px;
}

.role-name, .category-name {
    font-weight: 500;
    color: var(--text-color);
}

.role-count, .category-count {
    background: var(--primary-color);
    color: white;
    padding: 2px 8px;
    border-radius: 12px;
    font-size: 0.9rem;
}

.no-data {
    text-align: center;
    color: #999;
    padding: 20px;
}

@media (max-width: 768px) {
    .dashboard-row {
        grid-template-columns: 1fr;
    }
}
</style>